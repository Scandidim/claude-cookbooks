# ── Core AI ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key          # optional, for parallel tasks

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token  # from @BotFather

# ── Google Workspace ───────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
GOOGLE_DELEGATED_USER=admin@yourcompany.com

# ── KOMMO CRM ──────────────────────────────────────────────────────────────────
KOMMO_BASE_URL=https://yourcompany.kommo.com
KOMMO_ACCESS_TOKEN=your-kommo-long-lived-token

# ── Tilda ──────────────────────────────────────────────────────────────────────
TILDA_PUBLIC_KEY=your-tilda-public-key
TILDA_SECRET_KEY=your-tilda-secret-key

# ── WooCommerce Store ──────────────────────────────────────────────────────────
WOOCOMMERCE_URL=https://yourstore.com              # store root URL
WOOCOMMERCE_CONSUMER_KEY=ck_your-consumer-key      # from WooCommerce → Settings → Advanced → REST API
WOOCOMMERCE_CONSUMER_SECRET=cs_your-consumer-secret

# ── Nova Poshta (shipping, Ukraine) ────────────────────────────────────────────
NOVA_POSHTA_API_KEY=your-nova-poshta-api-key       # from novaposhta.ua cabinet

# ── S-VAULT Phantom (Firebase / Firestore) ─────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_FILE=/path/to/serviceAccountKey.json
SVAULT_APP_ID=phantom-final-v1
SVAULT_USER_ID=your-master-user-id        # Firebase UID of the vault owner

# ── Portal settings ────────────────────────────────────────────────────────────
PORTAL_NAME=My AI Portal
MAX_TASK_HISTORY=20
